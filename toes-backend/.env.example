# PostgreSQL connection URL (Render provides this automatically)
DATABASE_URL=postgres://user:password@host:5432/toes_backend_production

# Redis connection URL (Render Redis provides this automatically)
REDIS_URL=redis://localhost:6379/1

# Rails secret key base — generate with: bundle exec rails secret
# Also used as the JWT signing key.
SECRET_KEY_BASE=replace_with_output_of_rails_secret

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com

# Cloudinary — copy from your Cloudinary dashboard
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Admin seed credentials (used by db/seeds.rb on first deploy)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123!

# Puma threads / workers (Render sets PORT automatically)
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2

# Rails environment
RAILS_ENV=production
