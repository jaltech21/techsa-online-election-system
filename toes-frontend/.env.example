# ─── Local Development ───────────────────────────────────────────────────────
# Leave as-is for local dev. The Vite dev server proxies /api and /cable to
# localhost:3001 automatically, so VITE_API_BASE_URL is optional locally.
VITE_API_BASE_URL=http://localhost:3001

# ─── Production (Vercel) ─────────────────────────────────────────────────────
# Set this in your Vercel project dashboard under Settings → Environment Variables.
# Do NOT include a trailing slash.
# VITE_API_BASE_URL=https://your-app-name.onrender.com
